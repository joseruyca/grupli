SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_ANON_KEY=TU_PUBLISHABLE_O_ANON_KEY_PUBLICA
APP_BASE_URL=https://grupli.vercel.app

# Opcional: endpoint de autocompletado OpenStreetMap/Photon. No requiere API key.
# Puedes dejarlo vacío para usar https://photon.komoot.io/api/
OSM_GEOCODER_ENDPOINT=

# Opcional para push notifications reales (Firebase Cloud Messaging)
FIREBASE_API_KEY=
FIREBASE_APP_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_PROJECT_ID=
FIREBASE_VAPID_KEY=

# Estos NO son para la app Flutter. Son secretos de Edge Function; deben ir con Supabase secrets.
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
